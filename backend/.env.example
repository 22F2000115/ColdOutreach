# Secret key for signing JWT tokens. Auto-generated on first run if not set.
JWT_SECRET_KEY=your-secret-key-here

# Fernet encryption key for SMTP passwords. Auto-generated on first run if not set.
ENCRYPTION_KEY=your-fernet-key-here

# Groq API key for AI email generation (required for Outreach AI feature)
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini API key (primary AI provider)
GOOGLE_API_KEY=your-google-api-key-here

# Alternative/fallback Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated admin accounts in email:password format
# Example: admin@yoursite.com:strongpassword123
ADMIN_ACCOUNTS=admin@yoursite.com:changeme

# Database URL. Defaults to local SQLite if not set.
DATABASE_URL=sqlite:///./database.db

# Comma-separated allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173

# Set to "production" to enable secure cookies
ENV=development
